# ═══════════════════════════════════════════════════════════
# XOYO — Environment Variables Template
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════

# ── Groq (free LPU inference, ultra-fast) ──
GROQ_API_KEY=your_groq_api_key_here
GROQ_MAVERICK_API_KEY=your_groq_maverick_key_here

# ── Cerebras (free, 1M tokens/day) ──
CEREBRAS_API_KEY=your_cerebras_api_key_here

# ── Mistral (1B tokens/month free tier) ──
MISTRAL_API_KEY=your_mistral_api_key_here

# ── NVIDIA NIM (40 RPM free, 136 models) ──
NVIDIA_API_KEY=your_nvidia_api_key_here

# ── OpenRouter (50 req/day free) ──
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_API_KEYS=key1,key2,key3

# ── Cloudflare Workers AI ──
CLOUDFLARE_API_KEY=your_cloudflare_api_key_here

# ── SiliconFlow ──
SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# ── LLM7.io ──
LLM7_API_KEY=your_llm7_api_key_here

# ── Frontier Models ──
GEMINI_API_KEY=your_gemini_api_key_here

# ── Developer Password ──
XOYO_DEV_PASSWORD=your_dev_password_here
